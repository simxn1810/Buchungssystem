# ---------------------------------------------------------------------------
# Datenbank
# MVP: SQLite. Fuer Produktion (z. B. Vercel) auf PostgreSQL wechseln, indem
# in prisma/schema.prisma provider = "postgresql" gesetzt und hier eine
# Postgres-URL hinterlegt wird. Das Schema bleibt unveraendert.
# ---------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# ---------------------------------------------------------------------------
# Admin-Bereich (einfacher Passwortschutz fuer das MVP)
# ---------------------------------------------------------------------------
ADMIN_PASSWORD="bitte-aendern"

# ---------------------------------------------------------------------------
# Buchungsregeln (alle optional, Defaults siehe src/lib/config.ts)
# ---------------------------------------------------------------------------
OEFFNUNG_VON="07:00"
OEFFNUNG_BIS="23:00"
MIN_DAUER_MINUTEN="30"
MAX_DAUER_MINUTEN="180"
BUCHUNG_HORIZONT_TAGE="62"
# Reservierungsdauer der vorlaeufigen Buchung bis zur Code-Eingabe (Minuten)
CODE_GUELTIG_MINUTEN="10"
# Automatisches Loeschen von Buchungsdaten nach X Tagen (DSGVO)
DATEN_LOESCH_TAGE="60"

# Mitglied/Gast-Auswahl im Formular anzeigen (true/false)
# Laut offizieller Preisliste (Einzelstunde) gibt es keinen Mitglied/Gast-Unterschied,
# daher standardmaessig deaktiviert.
MITGLIED_AUSWAHL_AKTIV="false"

# Preise (in Cent)
LEIHSCHLAEGER_CENT_PRO_STUNDE="100"
BALL_PREIS_CENT="0"
ERMAESSIGUNG_CENT_PRO_STUNDE="200"

# ---------------------------------------------------------------------------
# E-Mail-Versand
# Variante A: Resend (REST-API, keine zusaetzliche Abhaengigkeit)
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="TC Frankenau <kontakt@tennis-frankenau.de>"

# Variante B: generisches SMTP (wird genutzt, wenn RESEND_API_KEY leer ist)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"

# Wenn weder Resend noch SMTP gesetzt sind, werden E-Mails in die Server-Konsole
# geschrieben (nur fuer lokale Entwicklung).

# ---------------------------------------------------------------------------
# SMS-Versand (optional). Ohne diese Werte ist nur der E-Mail-Kanal aktiv.
# Beispiel: Twilio (REST-API)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
